@model IEnumerable<EcommerceApp.Models.Entities.Category>
<div class="container mt-4">
    <h2>Category List</h2>
</div>
<a asp-area="Admin"
   asp-controller="Category"
   asp-action="Create">
    Create Category
</a>
@if (Model.Any())
{
    <table>
        <thead>
            <tr>
                <th>Id</th>
                <th>Name</th>
                <th>Display Order</th>
                <th>Action</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var category in Model)
            {
                <tr>
                    <td>@category.Id</td>
                    <td>@category.Name</td>
                    <td>@category.DisplayOrder</td>
                    <td><button>Edit</button></td>
                </tr>
            }
        </tbody>
    </table>
}
else
{
    <p>No categories found.</p>
}